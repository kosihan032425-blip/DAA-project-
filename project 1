def interpolation_search(arr, target):
    """
    Performs an interpolation search on a sorted, uniformly distributed list.
    Returns the index of the target if found, otherwise returns -1.
    """
    low = 0
    high = len(arr) - 1

    while low <= high and target >= arr[low] and target <= arr[high]:
        if low == high:
            if arr[low] == target:
                return low
            return -1

        # Probing formula to estimate the target's position
        pos = low + int(((float(high - low) / (arr[high] - arr[low])) * (target - arr[low])))

        if arr[pos] == target:
            return pos

        if arr[pos] < target:
            low = pos + 1
        else:
            high = pos - 1

    return -1


if __name__ == "__main__":
    try:
        # Get user input for the array elements
        user_input = input("Enter sorted, space-separated numbers: ")
        
        # Convert input string into a sorted list of integers
        sample_data = sorted([int(x) for x in user_input.split()])
        print(f"Searching within sorted array: {sample_data}")

        # Get user input for the target value to find
        target_value = int(input("Enter the target number to search for: "))

        result_index = interpolation_search(sample_data, target_value)

        if result_index != -1:
            print(f"Success: Element found at index {result_index}")
        else:
            print("Element not found in the array")
            
    except ValueError:
        print("Invalid input. Please enter numbers only.")
